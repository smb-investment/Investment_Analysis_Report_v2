# Local-only env for the analysis agent (NEVER commit this with real values).
# .env 도 .gitignore 의 .env* 에 포함되어 커밋되지 않습니다.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # service_role JWT. 사이트/GitHub 에 절대 넣지 말 것.

# ⚠️ ANTHROPIC_API_KEY 는 설정하지 마세요.
# Claude Code 구독제(Pro/Max)로 작동해야 하며, API 키가 설정되면 토큰당 과금됩니다.
