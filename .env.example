# Public — safe to commit (these are baked into the client bundle).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 사이트 절대주소 (어드민 알림 메일의 링크에 사용).
# Vercel 배포 도메인을 넣으면 메일의 "어드민 콘솔 열기" 버튼이 절대 URL이 됨.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ===== 어드민 알림 메일 (Resend) =====
# 신규 회원가입 시 어드민에게 메일 알림. 셋 중 하나라도 비어 있으면 알림은 조용히 스킵.
# RESEND_API_KEY: https://resend.com 가입 후 발급. 무료 플랜 월 3,000건.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# ADMIN_NOTIFY_EMAIL: 알림 받을 어드민 이메일 (예: sm@sunmyung.kr)
ADMIN_NOTIFY_EMAIL=admin@example.com
# NOTIFY_FROM_EMAIL: 보내는 사람. 도메인 인증 전에는 onboarding@resend.dev 그대로 사용 가능.
# 도메인 인증 후 noreply@your-domain.com 등으로 교체.
NOTIFY_FROM_EMAIL=onboarding@resend.dev

# DO NOT add SUPABASE_SERVICE_ROLE_KEY here.
# The service_role key bypasses RLS and must never be present on the site
# (this repo, Vercel, or the browser bundle). It is for the local
# analysis tooling in 2단계 only.
